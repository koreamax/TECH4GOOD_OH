# Gemini (민원 문안 생성) — 없으면 템플릿 폴백으로 동작
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Naver Cloud(NCP) Maps — 역지오코딩(주소 변환). 웹 지도와 같은 Application 인증키.
# NCP 콘솔 → Application(tech4good) → 인증키: Client ID + Client Secret 둘 다 필요.
# 없으면 주소 대신 좌표 문자열 폴백
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# DB — 비우면 로컬 SQLite. Supabase PostgreSQL 사용 시 Connect → URI 붙여넣기
DATABASE_URL=

# 서버 YOLO 추론 — best.pt 경로. 비우면 /infer·/infer/video 는 목 타임라인 반환
MODEL_PATH=

# HTTPS(자체 서명) — 로컬/직접 구동 시. 둘 다 지정하면 uvicorn 이 HTTPS 로 뜬다.
# 생성: sh scripts/gen-cert.sh   (docker compose 사용 시엔 compose 가 자동 주입)
SSL_CERTFILE=
SSL_KEYFILE=
