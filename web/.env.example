# 백엔드 주소. 로컬 개발 = http://localhost:8000
# 폰 브라우저/카메라 대체 영상 업로드는 서버로 전송되므로 배포 시 HTTPS 백엔드 URL 필수
VITE_API_URL=http://localhost:8000

# Naver 지도 Client ID (NCP 콘솔 → Maps). 비우면 지도 자리에 폴백 UI 표시.
VITE_NAVER_MAP_CLIENT_ID=

# 산책 화면 데모 영상 (public/ 하위 경로). 실제 촬영본으로 교체 가능.
VITE_DEMO_VIDEO=/demo-walk.mp4

# (레거시) 단일 프레임 추론 경로 토글. 영상 업로드 플로우에는 영향 없음.
VITE_USE_SERVER_INFER=false
